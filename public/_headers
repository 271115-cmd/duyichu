# Cloudflare Workers static-assets header rules (copied verbatim to dist/_headers
# by Vite). Format: a path pattern line, then indented "Name: value" pairs.

# Content-hashed build output (Vite puts a hash in every filename, so the bytes
# behind a given URL never change) — safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Baseline security headers on every response.
# CSP is ENFORCING (June 29 2026), verified live in-browser under enforcement.
# The Amap SDK uses eval() to load its WebGL renderer + ToolBar/Scale/MapType
# plugins, so script-src MUST include 'unsafe-eval' (Report-Only did NOT surface
# this — only live enforcement did). The real protection here is origin
# allowlisting: scripts/tiles only from self + *.amap.com / *.autonavi.com.
# Tuned to the site: only inline <script> is non-executable JSON-LD and there are
# zero inline on*= handlers (so no script 'unsafe-inline' needed); inline style=
# attrs need style 'unsafe-inline'; Draco needs 'wasm-unsafe-eval' + blob worker;
# Amap loads webapi.amap.com + runtime tiles on *.amap.com / *.autonavi.com.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval' https://webapi.amap.com https://*.amap.com https://*.autonavi.com blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.amap.com https://*.autonavi.com; font-src 'self'; connect-src 'self' https://*.amap.com https://*.autonavi.com; worker-src 'self' blob:; frame-src 'self' https://*.amap.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'
