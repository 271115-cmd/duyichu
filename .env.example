# Copy to .env.local and fill in. All keys are VITE_* (exposed to the client).

# Amap (高德) Web JS-API key → the interactive map on the home + Visit pages.
# Get one at console.amap.com (服务平台 = "Web端(JS API)"), then whitelist this
# site's domain on the key. Leave empty to use the keyless drawn SVG map.
VITE_AMAP_KEY=
